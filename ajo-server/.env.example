# Copy this file to .env and fill in real values.
# Full validation rules: src/config/app.config.ts

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/ajo

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Frontend / CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Nomba (virtual accounts, transfers, webhooks) ──────────────────────────
NOMBA_API_KEY=
NOMBA_SECRET_KEY=
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_WEBHOOK_SIGNATURE_KEY=

# ─── Mail (verification / password reset emails) ───────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Ajo App
